rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "ahamidplg@gmail.com";
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Settings Validation
    function isValidSettings(data) {
      return data.keys().hasAll(['updatedAt', 'updatedBy']) &&
             data.updatedAt is string &&
             data.updatedBy == request.auth.uid;
    }

    // Configs - Global
    match /configs/global {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidSettings(request.resource.data);
    }

    // User Settings
    match /users/{userId}/settings/{settingsId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isValidSettings(request.resource.data);
    }

    // Audit Logs
    match /audit_logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && 
                    request.resource.data.keys().hasAll(['alertId', 'action', 'timestamp', 'actor']) &&
                    request.resource.data.actor == request.auth.uid;
      allow update, delete: if false; // Immutable audit logs
    }
  }
}
